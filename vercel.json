{
  "framework": null,
  "outputDirectory": "web",
  "buildCommand": "",
  "installCommand": "npm install",
  "routes": [
    { "src": "^/$",                                       "dest": "/landing.html" },
    { "src": "^/briefings/?$",                            "dest": "/briefings/index.html" },
    { "src": "^/briefings/ko/([^/]+)/?$",                 "dest": "/briefings/$1-kospi.html" },
    { "src": "^/briefings/us/([^/]+)/?$",                 "dest": "/briefings/$1-us.html" },
    { "src": "^/briefings/ko-close/([^/]+)/?$",           "dest": "/briefings/ko-close/$1/index.html" },
    { "handle": "filesystem" }
  ]
}
