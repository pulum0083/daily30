<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dailyb.kospi</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/luke/Service App/DailyB/run_kospi.sh</string>
  </array>

  <!-- 월~금 08:30 KST (시스템 시간대가 Asia/Seoul 기준) -->
  <key>StartCalendarInterval</key>
  <array>
    <!-- Monday -->
    <dict>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>30</integer>
      <key>Weekday</key><integer>1</integer>
    </dict>
    <!-- Tuesday -->
    <dict>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>30</integer>
      <key>Weekday</key><integer>2</integer>
    </dict>
    <!-- Wednesday -->
    <dict>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>30</integer>
      <key>Weekday</key><integer>3</integer>
    </dict>
    <!-- Thursday -->
    <dict>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>30</integer>
      <key>Weekday</key><integer>4</integer>
    </dict>
    <!-- Friday -->
    <dict>
      <key>Hour</key><integer>8</integer>
      <key>Minute</key><integer>30</integer>
      <key>Weekday</key><integer>5</integer>
    </dict>
  </array>

  <key>StandardOutPath</key>
  <string>/Users/luke/Service App/DailyB/logs/launchd_kospi.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/luke/Service App/DailyB/logs/launchd_kospi_err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    <key>HOME</key>
    <string>/Users/luke</string>
  </dict>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
